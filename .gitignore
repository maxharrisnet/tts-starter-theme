# ============================================================
# TTS WordPress Starter Theme — .gitignore
# ============================================================


# ── Node / Vite ─────────────────────────────────────────────
node_modules/
assets/dist/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ── PHP / Composer ──────────────────────────────────────────
vendor/
composer.lock


# ── Environment & Secrets ───────────────────────────────────
.env
wp-config.php


# ── OS & Editor ─────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.sublime-project
*.sublime-workspace


# ── WordPress ───────────────────────────────────────────────
*.log
debug.log
error_log


# ── Build artifacts ─────────────────────────────────────────
*.map


# ── Testing ─────────────────────────────────────────────────
tests/coverage/
.phpunit.cache/


# ── Misc ────────────────────────────────────────────────────
*.bak
*.orig
*.tmp

# ── Local working material (not part of the theme) ─────────
AGENT/
populate-content.php
update-bio.php
